# ─────────────────────────────────────────────────────────────
# 운영 환경변수 템플릿(값은 넣지 말 것 · 실제 .env.production 은 gitignore).
# 운영 Vercel Production 환경변수에 등록하며, 스테이징과 완전히 분리한다.
# ⚠ service_role/비밀키는 절대 VITE_ 로 노출하지 않는다(서버/Edge 전용).
# ─────────────────────────────────────────────────────────────

# 운영 Supabase 프로젝트 URL
VITE_SUPABASE_URL=your-production-supabase-url

# 운영 anon(public) key
VITE_SUPABASE_ANON_KEY=your-production-anon-key

# 환경 구분
VITE_APP_ENV=production

# 운영 앱 URL(운영 도메인)
VITE_APP_URL=https://app.example.com

# 서버 전용(클라이언트 금지 — Vercel Server/Edge 환경에만):
#   SUPABASE_SERVICE_ROLE_KEY / DATABASE_URL / SMTP_* / *_API_KEY / *_SECRET
