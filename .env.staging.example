# ─────────────────────────────────────────────────────────────
# 스테이징 환경변수 템플릿(값은 넣지 말 것 · 실제 .env.staging 은 gitignore).
# 클라이언트(Vite)에는 VITE_ 접두사 공개값만. service_role/비밀키는 서버/Edge 에만 둔다.
# ⚠ 운영(production) 값을 복사하지 말 것 — 스테이징 전용 Supabase/Vercel 값 사용.
# ─────────────────────────────────────────────────────────────

# 스테이징 Supabase 프로젝트 URL (운영과 다른 프로젝트)
VITE_SUPABASE_URL=your-staging-supabase-url

# 스테이징 anon(public) key — RLS 보호 공개 키
VITE_SUPABASE_ANON_KEY=your-staging-anon-key

# 환경 구분(스테이징 표시/분기용). 미사용 코드에는 영향 없음.
VITE_APP_ENV=staging

# 스테이징 앱 URL(Auth redirect 등과 일치)
VITE_APP_URL=https://staging.example.com

# 서버 전용(클라이언트 금지 — 여기 두지 말고 Vercel Server/Edge 환경에만):
#   SUPABASE_SERVICE_ROLE_KEY / DATABASE_URL / SMTP_* / *_API_KEY / *_SECRET
